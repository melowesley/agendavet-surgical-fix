{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["@types/node"],
    "noEmit": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "supabase/functions/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
