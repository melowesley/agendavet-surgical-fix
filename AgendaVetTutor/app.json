{
  "expo": {
    "name": "AgendaVet - Tutor",
    "slug": "AgendaVet-Tutor-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agendavettutorapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.wesley9827.AgendaVetTutorApp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "pwa": {
        "name": "AgendaVet - Tutor",
        "shortName": "AV Tutor",
        "description": "App do Tutor AgendaVet",
        "backgroundColor": "#ffffff",
        "themeColor": "#007AFF",
        "display": "standalone",
        "orientation": "portrait"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Acesso à galeria para selecionar fotos dos seus pets.",
          "cameraPermission": "Câmera para tirar fotos dos seus pets."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Microfone necessário para gravar vídeos dos seus pets."
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "391e3804-c372-4f0a-a459-dff5e9b78a71"
      }
    }
  }
}